{
  "name": "devverse",
  "displayName": "DevVerse",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devverse.login",
        "title": "DevVerse: Login with GitHub"
      },
      {
        "command": "devverse.showStats",
        "title": "DevVerse: Show Session Stats"
      }
    ],
    "configuration": {
      "title": "DevVerse",
      "properties": {
        "devverse.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable DevVerse activity tracking."
        },
        "devverse.minSessionGapMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "Minutes of inactivity before a coding session is considered ended and flushed."
        },
        "devverse.languageMultipliers": {
          "type": "object",
          "default": {},
          "description": "Override the points multiplier per language ID (e.g. { \"go\": 2.0 }). Merged over the built-in defaults."
        }
      }
    }
  },
  "capabilities": {
    "authentication": {
      "github": {
        "scopes": ["read:user", "user:email"]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
